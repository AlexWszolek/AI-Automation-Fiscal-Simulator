{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "fiscal-model",
      "runtimeExecutable": ".venv/bin/streamlit",
      "runtimeArgs": [
        "run",
        "app/streamlit_app.py",
        "--server.headless",
        "true",
        "--server.port",
        "8501",
        "--browser.gatherUsageStats",
        "false"
      ],
      "port": 8501
    },
    {
      "name": "fiscal-web",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev",
        "--prefix",
        "web",
        "--",
        "--port",
        "5173",
        "--strictPort"
      ],
      "port": 5173
    },
    {
      "name": "fiscal-api",
      "runtimeExecutable": ".venv/bin/uvicorn",
      "runtimeArgs": [
        "api.main:app",
        "--port",
        "8000",
        "--log-level",
        "warning"
      ],
      "port": 8000
    }
  ]
}