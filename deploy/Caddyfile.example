# AI Automation Fiscal Simulator — Caddy config (generic; Caddy handles TLS automatically).
example.org {
    root * /srv/fiscal-simulator/web/dist
    encode gzip

    handle /api/* {
        reverse_proxy 127.0.0.1:8000
    }

    handle {
        try_files {path} /index.html
        file_server
    }
}
