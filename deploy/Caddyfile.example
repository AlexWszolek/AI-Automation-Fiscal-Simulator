# AI Automation Fiscal Simulator — Caddy config (generic; Caddy handles TLS automatically).
example.org {
    root * /srv/fiscal-simulator/web/dist
    encode gzip

    handle /api/* {
        reverse_proxy 127.0.0.1:8000
    }

    handle {
        # Hashed build outputs and fonts never change under the same name — cache forever.
        @immutable path /assets/* /fonts/*
        header @immutable Cache-Control "public, max-age=31536000, immutable"
        # Data bundles + generated pages change on redeploy — short cache, quick pickup.
        @data path /data/* /report.html /evidence.html
        header @data Cache-Control "public, max-age=3600"
        try_files {path} /index.html
        file_server
    }
}
